{
  "name": "@inlog/ds",
  "version": "1.1.0",
  "description": "Design System INLOG - Theme PrimeNG et tokens de design",
  "author": "INLOG",
  "license": "UNLICENSED",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme/group-theme.js",
      "types": "./dist/theme/group-theme.d.ts"
    }
  },
  "keywords": [
    "inlog",
    "design-system",
    "primeng",
    "angular",
    "theme"
  ],
  "scripts": {
    "build": "tsc --noEmitOnError false",
    "prepare": "tsc --noEmitOnError false"
  },
  "peerDependencies": {
    "@angular/core": ">=19.0.0",
    "primeng": ">=19.0.0",
    "@primeuix/themes": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    },
    "primeng": {
      "optional": true
    },
    "@primeuix/themes": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandrevallet/design-system.git"
  },
  "files": [
    "dist/",
    "src/"
  ]
}